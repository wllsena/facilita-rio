# ==============================================================================
# Synced from github.com/wllsena/deployer/rendered/facilita-rio/.env.example.
# Edit the deployer manifest at stacks/facilita-rio.yaml — NOT this file.
# Re-sync with: cp $DEPLOYER/rendered/facilita-rio/.env.example .env.hostinger.example
# (where DEPLOYER=~/Code/deployer).
# Local-dev defaults live in .env.example (different file).
# ==============================================================================

# =============================================================================
# Environment overrides for the facilita-rio stack — paste into the
# Hostinger Gerenciador Docker "Ambiente" panel of the facilita-rio
# stack. Lines with `KEY=value` are ready as-is; lines with `KEY=` followed
# by an inline hint need a value before the stack will start.
# =============================================================================

# Compose project name — namespaces Traefik routers across stacks. Leave
# unchanged unless renaming the stack in the Gerenciador.
COMPOSE_PROJECT_NAME=facilita-rio

# GHCR image selection. Pin IMAGE_TAG to a commit SHA for deterministic
# rollbacks; never deploy `:main` without recording the SHA it pointed at.
REGISTRY_OWNER=wllsena
IMAGE_TAG=main

# Public hostnames matched by Traefik. DNS for these must point at the VPS.
APP_HOST=facilita-rio.com


# Optional secret. Optional. From https://platform.openai.com/api-keys — enables LLM query enrichment.
OPENAI_API_KEY=
